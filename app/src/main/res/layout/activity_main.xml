<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/topHeader"
        android:layout_width="0dp"
        android:layout_height="320dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- penting: biru harus full tinggi header -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_top_gradient" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="145dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            android:src="@drawable/bg_wave_pink_real"
            android:contentDescription="@null" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="122dp"
            android:layout_gravity="bottom"
            android:scaleType="fitXY"
            android:src="@drawable/bg_wave_white_real"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="90dp"
            android:src="@drawable/logo_scira"
            android:contentDescription="Logo SCIRA"
            android:scaleType="fitCenter"
            android:elevation="10dp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/topHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome!"
            android:textColor="#000000"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="Pilih sebagai :"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTenagaMedis"
            android:layout_width="262dp"
            android:layout_height="58dp"
            android:layout_marginTop="42dp"
            android:background="@drawable/bg_button_gradient"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Tenaga Medis"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPasien"
            android:layout_width="262dp"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_outline"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Pasien"
            android:textAllCaps="false"
            android:textColor="#5F73D6"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>