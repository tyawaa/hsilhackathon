<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="115dp"
                android:background="@drawable/bg_header_dashboard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginEnd="22dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_logo_circle"
                        android:elevation="6dp">

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:contentDescription="Logo SCIRA"
                            android:scaleType="fitCenter"
                            android:src="@drawable/logo_scira" />
                    </FrameLayout>

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:layout_width="27dp"
                        android:layout_height="27dp"
                        android:layout_marginEnd="18dp"
                        android:contentDescription="Share"
                        android:src="@drawable/ic_menu_share" />

                    <ImageView
                        android:layout_width="27dp"
                        android:layout_height="27dp"
                        android:layout_marginEnd="18dp"
                        android:contentDescription="Email"
                        android:src="@drawable/ic_dialog_email" />

                    <ImageView
                        android:layout_width="27dp"
                        android:layout_height="27dp"
                        android:contentDescription="Profile"
                        android:src="@drawable/ic_menu_myplaces" />

                </LinearLayout>
            </FrameLayout>

            <!-- SEARCH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/search"
                        android:contentDescription="Search"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Obat diare"
                        android:textColor="#A8A8A8"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- PREDIKSI -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="248dp"
                android:layout_marginTop="22dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPrediksi"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="28dp"
                    android:layout_gravity="top"
                    android:elevation="4dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="#5C5EF0"
                    app:strokeWidth="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="30dp"
                        android:paddingTop="24dp"
                        android:paddingEnd="30dp"
                        android:paddingBottom="30dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Prediksi"
                                android:textColor="#000000"
                                android:textSize="31sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:lineSpacingExtra="6dp"
                                android:text="Memprediksi penyakit&#10;kulit"
                                android:textColor="#111111"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="102dp"
                            android:layout_height="102dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:contentDescription="Skin logo"
                            android:scaleType="fitCenter"
                            android:src="@drawable/skin_logo" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoScan"
                    android:layout_width="192dp"
                    android:layout_height="64dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="30dp"
                    android:backgroundTint="#DDE6F5"
                    android:elevation="14dp"
                    android:translationZ="14dp"
                    android:text="Go Scan"
                    android:textAllCaps="false"
                    android:textColor="#2E63B5"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>