<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pertanyaan Khusus Ekstra"
            android:textColor="#1A202C"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Bagian Bercak Merah -->
        <LinearLayout
            android:id="@+id/llBercakMerah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status Lesi" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakMenetap" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:id="@+id/rbBercakMenetap1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Menetap"/>
                <RadioButton android:id="@+id/rbBercakMenetap2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kekambuhan"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Apakah Baal (Mati Rasa)?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakBaal" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Apakah Nyeri?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakNyeri" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Apakah Gatal?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakGatal" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Pembesaran Saraf Secara Klinis?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakSaraf" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Kekuatan Otot Menurun?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakOtot" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Hewan Peliharaan Bulu Rontok?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakHewan" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Ada Central Healing?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakCentral" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Ada Hifa Sejati?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakHifa" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Ada Pseudohifa?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBercakPseudohifa" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>
        </LinearLayout>

        <!-- Bagian Bintil Merah -->
        <LinearLayout
            android:id="@+id/llBintilMerah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gatal Malam Hari?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBintilGatalMalam" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Orang Sekitar Terkena?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBintilSekitar" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Kontak Tanah / Pasir?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBintilTanah" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Apakah Gatal?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBintilGatal" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Apakah Perih?" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgBintilPerih" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ya"/>
                <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tidak"/>
            </RadioGroup>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLihatHasilAILanjut"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Lihat Hasil AI"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
